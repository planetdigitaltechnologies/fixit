# ── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── PostgreSQL ───────────────────────────────────────────────────────────────
# Local Docker (created by setup.sh):
DATABASE_URL=postgresql://fixit_user:fixit_local_pass@localhost:5432/fixit_db

# Production examples:
# Railway:  postgresql://postgres:PASSWORD@HOST:PORT/railway
# Render:   postgresql://fixit_user:PASSWORD@HOST/fixit_db
# Supabase: postgresql://postgres:PASSWORD@db.XXXXX.supabase.co:5432/postgres

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING
JWT_EXPIRES_IN=30d

# ── CORS ─────────────────────────────────────────────────────────────────────
# Your frontend URL (same origin in production since backend serves frontend)
FRONTEND_URL=http://localhost:4000

# ── File Uploads ──────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=5
UPLOAD_DIR=./uploads

# ── M-Pesa Daraja API (Safaricom) ─────────────────────────────────────────────
# Sign up at: https://developer.safaricom.co.ke
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=your_consumer_key_from_daraja
MPESA_CONSUMER_SECRET=your_consumer_secret_from_daraja
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_lipa_na_mpesa_online_passkey
MPESA_CALLBACK_URL=https://yourdomain.com/api/payments/mpesa/callback

# ── Kenya IPRS ID Verification ────────────────────────────────────────────────
# Contact: https://www.iprs.go.ke for API access
IPRS_API_URL=https://api.iprs.go.ke/verify
IPRS_API_KEY=your_iprs_api_key

# ── Push Notifications (VAPID) ────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:admin@yourdomain.com

# ── Email (optional – for account verification emails) ────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_gmail_app_password
