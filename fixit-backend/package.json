{
  "name": "fixit-backend",
  "version": "2.0.0",
  "description": "FixIt – Home Services Platform API (PostgreSQL + Express + WebSocket)",
  "main": "src/server.js",
  "scripts": {
    "start":   "node src/server.js",
    "dev":     "nodemon src/server.js",
    "migrate": "node src/migrate.js",
    "seed":    "node src/seed.js",
    "setup":   "node src/migrate.js && node src/seed.js",
    "reset":   "node src/reset.js"
  },
  "dependencies": {
    "bcryptjs":           "^2.4.3",
    "cors":               "^2.8.5",
    "dotenv":             "^16.3.1",
    "express":            "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet":             "^7.1.0",
    "jsonwebtoken":       "^9.0.2",
    "morgan":             "^1.10.0",
    "multer":             "^1.4.5-lts.1",
    "pg":                 "^8.11.3",
    "uuid":               "^9.0.0",
    "ws":                 "^8.14.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "nodemonConfig": {
    "watch": ["src"],
    "ext": "js,json",
    "ignore": ["uploads/*", "logs/*"],
    "delay": "500"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
